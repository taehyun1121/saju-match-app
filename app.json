{
  "expo": {
    "name": "사주매치",
    "slug": "saju-match",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.taehyun1121.sajumatch",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "위치 기반 매칭을 위해 위치 권한이 필요합니다."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8a573fac-642e-4102-8e3a-a38bb7bfc00e"
      }
    },
    "owner": "hataehyun"
  }
}
